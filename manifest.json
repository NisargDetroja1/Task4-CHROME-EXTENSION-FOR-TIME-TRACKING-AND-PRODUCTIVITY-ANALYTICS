{
  "manifest_version": 3,

  "name": "Advanced Productivity Tracker",

  "version": "2.0",

  "description": "Tracks browsing time and productivity analytics",

  "permissions": [
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  }
}